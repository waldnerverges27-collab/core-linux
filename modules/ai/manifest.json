      "version_cmd": "codegraph --version 2>/dev/null || echo 'latest'",
      "install": {
        "default": "curl -fsSL https://github.com/sourcegraph/codegraph/releases/latest/download/codegraph-linux-amd64 -o /usr/local/bin/codegraph && chmod +x /usr/local/bin/codegraph"
      },
