{
  "$schema": "core-linux-module-v1",
  "name": "ai",
  "version": "1.0.0",
  "description": "AI agents and coding assistants",
  "author": "core-linux",
  "icon": "🤖",
  "dependencies": ["lang"],
  "conflicts": [],
  "platform": {
    "min_ram_mb": 2048,
    "requires_gpu": false,
    "supported_distros": ["ubuntu", "fedora", "arch", "opensuse", "void"]
  },
  "tools": [
    {
      "name": "qwen-code",
      "flag": "--qwen-code",
      "description": "Alibaba's AI coding assistant",
      "version_cmd": "qwen --version 2>/dev/null || echo 'latest'",
      "install": {
        "default": "npm install -g @qwen/qwen-code-cli"
      },
      "uninstall": {
        "default": "npm uninstall -g @qwen/qwen-code-cli"
      },
      "size_mb": 50,
      "tags": ["ai", "code", "alibaba"]
    },
    {
      "name": "gemini-cli",
      "flag": "--gemini-cli",
      "description": "Google's AI assistant with Gemini",
      "version_cmd": "gemini --version 2>/dev/null || echo 'latest'",
      "install": {
        "default": "npm install -g @google/gemini-cli"
      },
      "uninstall": {
        "default": "npm uninstall -g @google/gemini-cli"
      },
      "size_mb": 50,
      "tags": ["ai", "google", "gemini"]
    },
    {
      "name": "claude-code",
      "flag": "--claude-code",
      "description": "Anthropic's CLI tool with Claude AI",
      "version_cmd": "claude --version 2>/dev/null || echo 'latest'",
      "install": {
        "ubuntu": "curl -fsSL https://github.com/anthropics/claude-code/releases/latest/download/claude-linux-amd64.tar.gz | sudo tar -xz -C /usr/local/bin claude",
        "fedora": "curl -fsSL https://github.com/anthropics/claude-code/releases/latest/download/claude-linux-amd64.tar.gz | sudo tar -xz -C /usr/local/bin claude",
        "arch": "curl -fsSL https://github.com/anthropics/claude-code/releases/latest/download/claude-linux-amd64.tar.gz | sudo tar -xz -C /usr/local/bin claude",
        "default": "curl -fsSL https://github.com/anthropics/claude-code/releases/latest/download/claude-linux-amd64.tar.gz | sudo tar -xz -C /usr/local/bin claude"
      },
      "uninstall": {
        "default": "sudo rm -f /usr/local/bin/claude"
      },
      "size_mb": 80,
      "tags": ["ai", "anthropic", "claude"]
    },
    {
      "name": "mistral-vibe",
      "flag": "--mistral-vibe",
      "description": "Command-line coding assistant powered by Mistral's models",
      "version_cmd": "vibe --version 2>/dev/null || echo 'latest'",
      "install": {
        "default": "npm install -g mistral-vibe-cli"
      },
      "uninstall": {
        "default": "npm uninstall -g mistral-vibe-cli"
      },
      "size_mb": 40,
      "tags": ["ai", "mistral", "code"]
    },
    {
      "name": "openclaude",
      "flag": "--openclaude",
      "description": "Open source Claude Code alternative",
      "version_cmd": "openclaude --version 2>/dev/null || echo 'latest'",
      "install": {
        "default": "curl -fsSL https://github.com/sst/OpenClaude/releases/latest/download/openclaude-linux-amd64 -o /usr/local/bin/openclaude && chmod +x /usr/local/bin/openclaude"
      },
      "uninstall": {
        "default": "sudo rm -f /usr/local/bin/openclaude"
      },
      "size_mb": 30,
      "tags": ["ai", "open-source", "claude"]
    },
    {
      "name": "openclaw",
      "flag": "--openclaw",
      "description": "Personal AI Assistant",
      "version_cmd": "openclaw --version 2>/dev/null || echo 'latest'",
      "install": {
        "default": "curl -fsSL https://github.com/OpenClaw/OpenClaw/releases/latest/download/openclaw-linux-amd64 -o /usr/local/bin/openclaw && chmod +x /usr/local/bin/openclaw"
      },
      "uninstall": {
        "default": "sudo rm -f /usr/local/bin/openclaw"
      },
      "size_mb": 30,
      "tags": ["ai", "assistant"]
    },
    {
      "name": "ollama",
      "flag": "--ollama",
      "description": "Run open-source LLMs locally",
      "version_cmd": "ollama --version 2>/dev/null | cut -d' ' -f2",
      "install": {
        "ubuntu": "curl -fsSL https://ollama.com/install.sh | sh",
        "fedora": "curl -fsSL https://ollama.com/install.sh | sh",
        "arch": "curl -fsSL https://ollama.com/install.sh | sh",
        "opensuse": "curl -fsSL https://ollama.com/install.sh | sh",
        "default": "curl -fsSL https://ollama.com/install.sh | sh"
      },
      "uninstall": {
        "ubuntu": "sudo systemctl stop ollama 2>/dev/null; sudo rm -rf /usr/local/lib/ollama /usr/local/bin/ollama",
        "default": "sudo rm -rf /usr/local/lib/ollama /usr/local/bin/ollama"
      },
      "post_install": "systemctl --user enable ollama 2>/dev/null || true",
      "size_mb": 500,
      "tags": ["ai", "llm", "local", "inference"]
    },
    {
      "name": "codex",
      "flag": "--codex",
      "description": "OpenAI coding agent that runs locally on your computer",
      "version_cmd": "codex --version 2>/dev/null || echo 'latest'",
      "install": {
        "default": "npm install -g @openai/codex"
      },
      "uninstall": {
        "default": "npm uninstall -g @openai/codex"
      },
      "size_mb": 60,
      "tags": ["ai", "openai", "code"]
    },
    {
      "name": "opencode",
      "flag": "--opencode",
      "description": "Open-source agent that helps you write code in your terminal",
      "version_cmd": "opencode --version 2>/dev/null || echo 'latest'",
      "install": {
        "default": "curl -fsSL https://github.com/anomalyco/opencode/releases/latest/download/opencode-linux-amd64.tar.gz | sudo tar -xz -C /usr/local/bin opencode && chmod +x /usr/local/bin/opencode"
      },
      "uninstall": {
        "default": "sudo rm -f /usr/local/bin/opencode"
      },
      "size_mb": 40,
      "tags": ["ai", "open-source", "code"]
    },
    {
      "name": "qoder",
      "flag": "--qoder",
      "description": "A terminal-native AI coding partner and agent engine",
      "version_cmd": "qoder --version 2>/dev/null || echo 'latest'",
      "install": {
        "default": "curl -fsSL https://github.com/qoder/qoder/releases/latest/download/qoder-linux-amd64 -o /usr/local/bin/qoder && chmod +x /usr/local/bin/qoder"
      },
      "uninstall": {
        "default": "sudo rm -f /usr/local/bin/qoder"
      },
      "size_mb": 40,
      "tags": ["ai", "code", "terminal"]
    },
    {
      "name": "kilocode-cli",
      "flag": "--kilocode-cli",
