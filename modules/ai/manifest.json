      "version_cmd": "kimchi --version 2>/dev/null || echo 'latest'",
      "install": {
        "default": "npm install -g kimchi-cli"
      },
      "uninstall": {
        "default": "npm uninstall -g kimchi-cli"
      },
      "size_mb": 40,
      "tags": ["ai", "code", "multi-model"]
    },
    {
      "name": "mimocode",
      "flag": "--mimocode",
      "description": "Xiaomi's AI coding agent — fast, local, and open-source",
      "version_cmd": "mimo --version 2>/dev/null || echo 'latest'",
      "install": {
        "default": "curl -fsSL https://github.com/XiaomiMiMo/MiMo-Code/releases/latest/download/mimocode-linux-amd64.tar.gz | sudo tar -xz -C /usr/local/bin mimo && mv /usr/local/bin/mimo /usr/local/bin/mimocode 2>/dev/null; chmod +x /usr/local/bin/mimocode"
      },
      "uninstall": {
        "default": "sudo rm -f /usr/local/bin/mimocode"
      },
      "size_mb": 40,
      "tags": ["ai", "xiaomi", "code"]
    },
    {
      "name": "engram",
      "flag": "--engram",
      "description": "Persistent memory system for coding agents",
      "version_cmd": "engram --version 2>/dev/null || echo 'latest'",
      "install": {
        "default": "curl -fsSL https://github.com/engram/engram-cli/releases/latest/download/engram-linux-amd64 -o /usr/local/bin/engram && chmod +x /usr/local/bin/engram"
      },
      "uninstall": {
        "default": "sudo rm -f /usr/local/bin/engram"
