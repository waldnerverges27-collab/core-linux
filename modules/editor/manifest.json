{
  "$schema": "core-linux-module-v1",
  "name": "editor",
  "version": "1.0.0",
  "description": "Code editors and IDEs",
  "author": "core-linux",
  "icon": "✏️",
  "dependencies": [],
  "conflicts": [],
  "platform": {
    "min_ram_mb": 512,
    "requires_gpu": false,
    "supported_distros": ["ubuntu", "fedora", "arch", "opensuse", "void"]
  },
  "tools": [
    {
      "name": "neovim",
      "flag": "--neovim",
      "description": "Modern Vim-based text editor",
      "version_cmd": "nvim --version 2>/dev/null | head -1 | grep -oP 'v\\K[0-9.]+'",
      "install": {
        "ubuntu": "sudo apt-get install -y neovim",
        "fedora": "sudo dnf install -y neovim",
        "arch": "sudo pacman -S --noconfirm neovim",
        "opensuse": "sudo zypper install -y neovim",
        "void": "sudo xbps-install -y neovim"
      },
      "uninstall": {
        "ubuntu": "sudo apt-get remove -y neovim",
        "arch": "sudo pacman -Rns --noconfirm neovim",
        "default": "sudo apt-get remove -y neovim"
      },
      "size_mb": 80,
      "tags": ["editor", "vim", "terminal"]
    },
    {
      "name": "vscode",
      "flag": "--vscode",
      "description": "Visual Studio Code editor",
      "version_cmd": "code --version 2>/dev/null | head -1",
      "install": {
        "ubuntu": "wget -qO- https://packages.microsoft.com/keys/microsoft.asc | gpg --dearmor | sudo tee /etc/apt/keyrings/packages.microsoft.gpg > /dev/null && echo 'deb [arch=amd64 signed-by=/etc/apt/keyrings/packages.microsoft.gpg] https://packages.microsoft.com/repos/code stable main' | sudo tee /etc/apt/sources.list.d/vscode.list && sudo apt-get update && sudo apt-get install -y code",
        "fedora": "sudo rpm --import https://packages.microsoft.com/keys/microsoft.asc && echo -e '[code]\nname=Visual Studio Code\nbaseurl=https://packages.microsoft.com/yumrepos/vscode\nenabled=1\ngpgcheck=1\ngpgkey=https://packages.microsoft.com/keys/microsoft.asc' | sudo tee /etc/yum.repos.d/vscode.repo && sudo dnf install -y code",
        "arch": "yay -S --noconfirm visual-studio-code-bin",
        "default": "wget -qO- https://packages.microsoft.com/keys/microsoft.asc | gpg --dearmor | sudo tee /etc/apt/keyrings/packages.microsoft.gpg > /dev/null && echo 'deb [arch=amd64 signed-by=/etc/apt/keyrings/packages.microsoft.gpg] https://packages.microsoft.com/repos/code stable main' | sudo tee /etc/apt/sources.list.d/vscode.list && sudo apt-get update && sudo apt-get install -y code"
      },
      "uninstall": {
        "ubuntu": "sudo apt-get remove -y code",
        "arch": "yay -Rns --noconfirm visual-studio-code-bin",
        "default": "sudo apt-get remove -y code"
      },
      "size_mb": 300,
      "tags": ["editor", "ide", "microsoft"]
    },
    {
      "name": "helix",
      "flag": "--helix",
      "description": "Modal text editor with built-in LSP",
      "version_cmd": "hx --version 2>/dev/null | head -1 | cut -d' ' -f2",
      "install": {
        "ubuntu": "sudo add-apt-repository -y ppa:maveonair/helix && sudo apt-get update && sudo apt-get install -y helix",
        "fedora": "sudo dnf install -y helix",
        "arch": "sudo pacman -S --noconfirm helix",
        "opensuse": "sudo zypper install -y helix",
        "void": "sudo xbps-install -y helix",
        "default": "wget -qO- https://github.com/helix-editor/helix/releases/download/24.03/helix-24.03-x86_64-linux.tar.xz | sudo tar -xJ -C /usr/local --strip=1"
      },
      "uninstall": {
        "ubuntu": "sudo apt-get remove -y helix",
        "arch": "sudo pacman -Rns --noconfirm helix",
        "default": "sudo rm -f /usr/local/bin/hx"
      },
      "size_mb": 30,
      "tags": ["editor", "terminal", "lsp"]
    },
    {
      "name": "zed",
      "flag": "--zed",
      "description": "High-performance code editor by Atom authors",
      "version_cmd": "zed --version 2>/dev/null | cut -d' ' -f2",
      "install": {
        "ubuntu": "curl -fsSL https://zed.dev/install.sh | sh",
        "arch": "yay -S --noconfirm zed",
        "default": "curl -fsSL https://zed.dev/install.sh | sh"
      },
      "uninstall": {
        "arch": "yay -Rns --noconfirm zed",
        "default": "rm -f ~/.local/bin/zed"
      },
      "size_mb": 200,
      "tags": ["editor", "gui", "rust"]
    },
    {
      "name": "emacs",
      "flag": "--emacs",
      "description": "Extensible, customizable text editor",
      "version_cmd": "emacs --version 2>/dev/null | head -1 | cut -d' ' -f3",
      "install": {
        "ubuntu": "sudo apt-get install -y emacs",
        "fedora": "sudo dnf install -y emacs",
        "arch": "sudo pacman -S --noconfirm emacs",
        "opensuse": "sudo zypper install -y emacs",
        "void": "sudo xbps-install -y emacs"
      },
      "uninstall": {
        "ubuntu": "sudo apt-get remove -y emacs",
        "arch": "sudo pacman -Rns --noconfirm emacs",
        "default": "sudo apt-get remove -y emacs"
      },
      "size_mb": 200,
      "tags": ["editor", "extensible"]
    },
    {
      "name": "micro",
      "flag": "--micro",
      "description": "Modern and intuitive terminal editor",
      "version_cmd": "micro --version 2>/dev/null | cut -d' ' -f2",
      "install": {
        "ubuntu": "curl -fsSL https://getmic.ro | bash && sudo mv micro /usr/local/bin/",
        "arch": "sudo pacman -S --noconfirm micro",
        "opensuse": "sudo zypper install -y micro",
        "default": "curl -fsSL https://getmic.ro | bash && sudo mv micro /usr/local/bin/"
      },
      "uninstall": {
        "arch": "sudo pacman -Rns --noconfirm micro",
        "default": "sudo rm -f /usr/local/bin/micro"
      },
      "size_mb": 10,
      "tags": ["editor", "terminal", "simple"]
    }
  ]
}
