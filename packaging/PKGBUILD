# Maintainer: core-linux <dev@core-linux.dev>
# Contributor: core-linux

pkgname=core-linux
pkgver=1.0.0
pkgrel=1
pkgdesc="Modular Development Environment for Linux terminals"
arch=('x86_64' 'aarch64')
url="https://github.com/waldnerverges27-collab/core-linux"
license=('MIT')
depends=('bash>=5.0' 'curl' 'git' 'jq' 'fzf')
makedepends=('go>=1.22')
source=("$pkgname-$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
	cd "$srcdir/$pkgname-$pkgver"
	cd cmd/core-tui
	go build -ldflags="-s -w" -o core-tui .
}

package() {
	cd "$srcdir/$pkgname-$pkgver"
	install -Dm755 core "$pkgdir/usr/bin/core"
	install -Dm755 cmd/core-tui/core-tui "$pkgdir/usr/bin/core-tui" 2>/dev/null || true

	install -dm755 "$pkgdir/usr/share/core-linux"
	cp -r modules "$pkgdir/usr/share/core-linux/"
	cp -r lib "$pkgdir/usr/share/core-linux/"
	cp -r plugins "$pkgdir/usr/share/core-linux/" 2>/dev/null || true
}
