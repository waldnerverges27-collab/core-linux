[core]
version = "1.0.0"
home = "CORE_HOME_PLACEHOLDER"
theme = "catppuccin-mocha"
editor = "vim"

[tui]
animation_speed = "normal"
border_style = "rounded"

[brain]
sync_remote = ""

[modules]
auto_verify = true

[colors]
primary = "#cba6f7"
secondary = "#89b4fa"
accent = "#f38ba8"
success = "#a6e3a1"
warning = "#f9e2af"
error = "#f38ba8"
bg = "#1e1e2e"
surface = "#313244"
text = "#cdd6f4"
muted = "#6c7086"
border = "#45475a"
